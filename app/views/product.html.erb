<% 
    product = Product.find(@req.params['id']) 
    unless product
        return redirect_to('/shop')
    end

    # SEO Meta Tags
    @title = "#{product.name} - Antivoid Shop"
    @description = product.description[0..155]
    @og_image = product.image_url
%>

<!-- JSON-LD Structured Data for Google -->
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": "<%= product.name %>",
  "image": "<%= product.image_url %>",
  "description": "<%= product.description.gsub('"', '\"') %>",
  "brand": {
    "@type": "Brand",
    "name": "Antivoid"
  },
  "offers": {
    "@type": "Offer",
    "url": "<%= @req.url %>",
    "priceCurrency": "IDR",
    "price": "<%= product.price %>",
    "availability": "https://schema.org/<%= product.stock > 0 ? 'InStock' : 'OutOfStock' %>",
    "itemCondition": "https://schema.org/NewCondition"
  }
}
</script>
<div class="max-w-7xl mx-auto px-6 py-12 animate__animated animate__fadeIn">
    <!-- Breadcrumb -->
    <nav class="flex mb-10 overflow-x-auto whitespace-nowrap pb-2" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li class="inline-flex items-center">
                <a href="/" class="text-sm font-medium text-slate-500 hover:text-indigo-600 flex items-center gap-2">
                    <i data-lucide="home" class="w-4 h-4"></i> Beranda
                </a>
            </li>
            <li>
                <div class="flex items-center text-slate-400">
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                    <a href="/shop" class="ml-1 text-sm font-medium text-slate-500 hover:text-indigo-600 md:ml-2">Belanja</a>
                </div>
            </li>
            <li aria-current="page">
                <div class="flex items-center text-slate-400">
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                    <span class="ml-1 text-sm font-bold text-slate-900 md:ml-2 line-clamp-1"><%= product.name %></span>
                </div>
            </li>
        </ol>
    </nav>

    <div class="lg:grid lg:grid-cols-2 lg:gap-x-12 lg:items-start">
        <!-- Image Gallery -->
        <div class="animate__animated animate__fadeInLeft">
            <div class="glass p-4 rounded-[40px] shadow-2xl border border-white/60 overflow-hidden group">
                <div class="aspect-square bg-slate-100 rounded-[30px] overflow-hidden relative">
                    <img src="<%= product.image_url || 'https://via.placeholder.com/800' %>" 
                        alt="<%= product.name %>" 
                        class="w-full h-full object-center object-cover transition duration-700 group-hover:scale-105">
                    <div class="absolute top-6 left-6">
                        <span class="glass-dark text-white text-xs px-4 py-1.5 rounded-full font-bold uppercase tracking-widest bg-indigo-600/80">Kualitas Premium</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Specs -->
        <div class="mt-12 px-2 sm:mt-16 lg:mt-0 animate__animated animate__fadeInRight">
            <div class="mb-8">
                <span class="text-xs font-bold text-indigo-600 uppercase tracking-widest bg-indigo-50 px-3 py-1 rounded-full mb-4 inline-block">
                    <%= Category.all.find{|c| c.id.to_s == product.category_id}&.name || 'Uncategorized' %>
                </span>
                <h1 class="text-4xl md:text-5xl font-black text-slate-900 mb-4"><%= product.name %></h1>
                <p class="text-4xl font-black text-indigo-600"><%= ViewHelper.format_rupiah(product.price) %></p>
            </div>

            <div class="glass p-8 rounded-3xl border border-white/60 mb-8">
                <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
                    <i data-lucide="align-left" class="w-5 h-5 text-indigo-600"></i> Deskripsi Produk
                </h3>
                <div class="prose prose-slate text-slate-500 leading-relaxed">
                    <%= product.description %>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-10">
                <div class="glass p-4 rounded-2xl border border-white/40 flex items-center gap-4">
                    <div class="w-10 h-10 bg-green-100 text-green-600 rounded-xl flex items-center justify-center">
                        <i data-lucide="check-circle" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <p class="text-xs text-slate-400 uppercase font-bold tracking-tighter">Status</p>
                        <p class="text-sm font-bold text-slate-800"><%= product.stock > 0 ? 'Tersedia' : 'Habis' %></p>
                    </div>
                </div>
                <div class="glass p-4 rounded-2xl border border-white/40 flex items-center gap-4">
                    <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center">
                        <i data-lucide="package" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <p class="text-xs text-slate-400 uppercase font-bold tracking-tighter">Stok</p>
                        <p class="text-sm font-bold text-slate-800"><%= product.stock %> Unit</p>
                    </div>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-4">
                <% if product.stock > 0 %>
                    <form action="/cart/add" method="POST" class="flex flex-col sm:flex-row gap-4 flex-grow">
                        <input type="hidden" name="product_id" value="<%= product.id %>">
                        <div class="glass rounded-2xl border border-white/60 p-1 flex items-center">
                            <button type="button" onclick="this.nextElementSibling.stepDown()" class="w-12 h-12 flex items-center justify-center text-slate-400 hover:text-indigo-600"><i data-lucide="minus" class="w-5 h-5"></i></button>
                            <input type="number" name="quantity" value="1" min="1" max="<%= product.stock %>" 
                                class="w-16 bg-transparent text-center font-bold text-lg outline-none appearance-none">
                            <button type="button" onclick="this.previousElementSibling.stepUp()" class="w-12 h-12 flex items-center justify-center text-slate-400 hover:text-indigo-600"><i data-lucide="plus" class="w-5 h-5"></i></button>
                        </div>
                        <button type="submit" class="flex-grow bg-indigo-600 text-white px-10 py-4 rounded-2xl font-bold text-lg shadow-xl shadow-indigo-100 hover:bg-slate-900 transition flex items-center justify-center gap-3 active:scale-95">
                            <i data-lucide="shopping-cart" class="w-6 h-6"></i> Masukkan ke Keranjang
                        </button>
                    </form>
                <% else %>
                    <div class="flex-grow flex items-center justify-center bg-slate-200 text-slate-500 px-10 py-4 rounded-2xl font-bold text-lg shadow-inner cursor-not-allowed border border-slate-300 gap-3">
                        <i data-lucide="package-x" class="w-6 h-6 mr-2"></i> Stok Habis
                    </div>
                <% end %>
                <form action="/wishlist/add" method="POST" class="flex-shrink-0 flex items-stretch">
                    <input type="hidden" name="product_id" value="<%= product.id %>">
                    <button type="submit" class="h-full glass p-4 rounded-2xl border border-white/60 text-indigo-600 hover:bg-indigo-600 hover:text-white transition group active:scale-95 flex items-center justify-center">
                        <i data-lucide="heart" class="w-6 h-6 transition-transform group-hover:scale-110"></i>
                    </button>
                </form>
            </div>

            <!-- Product Meta Info -->
            <div class="mt-12 flex items-center gap-6 pb-12 border-b border-indigo-100/50">
                <div class="flex -space-x-2">
                    <img src="https://i.pravatar.cc/100?u=1" class="w-8 h-8 rounded-full border-2 border-white">
                    <img src="https://i.pravatar.cc/100?u=2" class="w-8 h-8 rounded-full border-2 border-white">
                    <img src="https://i.pravatar.cc/100?u=3" class="w-8 h-8 rounded-full border-2 border-white">
                </div>
                <p class="text-sm text-slate-500 font-medium">12+ orang membeli produk ini hari ini</p>
            </div>

            <!-- Reviews Section -->
            <div class="mt-12">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-2xl font-black text-slate-900 flex items-center gap-3">
                        <i data-lucide="star" class="w-8 h-8 text-yellow-500 fill-yellow-500"></i> Ulasan Produk
                    </h3>
                    <% reviews = Review.all_for_product(product.id) %>
                    <span class="text-sm font-bold text-slate-500 bg-white/50 px-4 py-1.5 rounded-full border border-white/60">
                        <%= reviews.size %> Ulasan
                    </span>
                </div>

                <!-- Review Form (Only for logged in) -->
                <% if AuthHelper.authenticated?(@req) %>
                    <div class="glass p-5 sm:p-8 rounded-[32px] border border-white/60 mb-10 shadow-lg shadow-indigo-50/50">
                        <h4 class="text-lg font-black text-slate-800 mb-6 italic">Bagaimana pengalaman belanja Anda?</h4>
                        <form action="/product/review" method="POST" class="space-y-4">
                            <input type="hidden" name="product_id" value="<%= product.id %>">
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Rating</label>
                                <div class="flex flex-wrap gap-2">
                                    <% (1..5).each do |i| %>
                                        <label class="cursor-pointer group">
                                            <input type="radio" name="rating" value="<%= i %>" class="hidden peer" required <%= 'checked' if i == 5 %>>
                                            <div class="p-2 sm:p-3 rounded-xl border border-slate-200 bg-white peer-checked:bg-yellow-400 peer-checked:border-yellow-500 transition-all active:scale-95">
                                                <i data-lucide="star" class="w-5 h-5 sm:w-6 sm:h-6 text-slate-300 peer-checked:text-white peer-checked:fill-white group-hover:scale-110 transition"></i>
                                            </div>
                                        </label>
                                    <% end %>
                                </div>
                            </div>
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Komentar</label>
                                <textarea name="comment" required placeholder="Ceritakan detail produk..." 
                                    class="w-full glass bg-white/20 border border-white/40 rounded-2xl p-6 outline-none focus:ring-2 focus:ring-indigo-500 transition text-slate-700"></textarea>
                            </div>
                            <button type="submit" class="bg-indigo-600 text-white px-8 py-3 rounded-2xl font-bold hover:bg-slate-900 transition flex items-center gap-2 group">
                                Kirim Ulasan <i data-lucide="send" class="w-5 h-5 group-hover:translate-x-1 transition"></i>
                            </button>
                        </form>
                    </div>
                <% else %>
                    <div class="glass p-8 rounded-[32px] border border-white/60 text-center mb-10 bg-indigo-50/30">
                        <p class="text-slate-600 font-medium">Silakan <a href="/login" class="text-indigo-600 font-bold hover:underline">masuk</a> untuk memberikan ulasan produk.</p>
                    </div>
                <% end %>

                <!-- List of Reviews -->
                <div class="space-y-6">
                    <% if reviews.empty? %>
                        <div class="text-center py-10">
                            <i data-lucide="message-square" class="w-12 h-12 text-slate-300 mx-auto mb-4"></i>
                            <p class="text-slate-500 font-medium">Belum ada ulasan untuk produk ini.</p>
                        </div>
                    <% else %>
                        <% reviews.each do |review| %>
                            <div class="glass p-4 sm:p-6 rounded-3xl border border-white/60 hover:bg-white/40 transition">
                                <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center font-black">
                                            <%= review.user_name[0].upcase %>
                                        </div>
                                        <div>
                                            <p class="font-bold text-slate-900 line-clamp-1"><%= review.user_name %></p>
                                            <div class="flex gap-0.5">
                                                <% (1..5).each do |i| %>
                                                    <i data-lucide="star" class="w-3 h-3 <%= i <= review.rating ? 'text-yellow-400 fill-yellow-400' : 'text-slate-200' %>"></i>
                                                <% end %>
                                            </div>
                                        </div>
                                    </div>
                                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                                        <%= review.created_at.strftime("%d %b %Y") %>
                                    </span>
                                </div>
                                <p class="text-slate-600 leading-relaxed italic">"<%= review.comment %>"</p>
                            </div>
                        <% end %>
                    <% end %>
                </div>
            </div>
        </div>
    </div>
</div>
